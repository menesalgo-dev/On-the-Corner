# On The Corner — env template
# Copia questo file in .env.local e riempi i valori reali.
# .env.local è ignorato da git (mai committarlo!).
# ════════════════════════════════════════════════════════════════

# ───── Supabase (OBBLIGATORI) ─────
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...  # ⚠️ MAI esporre lato client

# ───── Site ─────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ───── API Sport (opzionali per ora, servono dalla Settimana 3) ─────
